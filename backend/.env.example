# SentinelAI Backend Environment Template (.env.example)

PROJECT_NAME="SentinelAI"
VERSION="1.0.0"
ENVIRONMENT="development"
SECRET_KEY="your-random-32-character-secret-key-here"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Databases
DATABASE_URL="postgresql://user:password@localhost:5432/sentinel_db"
SQLITE_FALLBACK_URL="sqlite:///./sentinel.db"
REDIS_URL="redis://localhost:6379/0"

# LLM Providers & Models
LLM_PROVIDER="local" # Options: local | gemini | openai
LOCAL_LLM_BASE_URL="http://localhost:11434/v1"
MODEL_TRIAGE_SEVERITY="phi-4-mini:Q4_K_M"
MODEL_FORENSICS_MITIGATION="qwen2.5-coder:3b-instruct"
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Alerts, Notifications & SMTP Email
ADMIN_EMAIL="sec_admin@sentinelai.local"
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SLACK_WEBHOOK_URL=""

# Security & Monitoring
ENABLE_PROMETHEUS_METRICS=true
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
